<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>لوحة المسؤول</title>

<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;800;900&display=swap" rel="stylesheet">

<style>
:root{
  --primary:#0f172a;
  --bg1:#eef4ff;
  --bg2:#dff1ff;
  --card:#ffffff;
  --line:#e2e8f0;
  --shadow:0 30px 70px rgba(15,23,42,.15);
}

*{box-sizing:border-box}
body{
  margin:0;
  font-family:'Cairo',sans-serif;
  background:linear-gradient(135deg,var(--bg1),var(--bg2));
}

.topbar{
  background:var(--primary);
  color:#fff;
  padding:16px 24px;
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.logout-btn{
  background:#fff;
  color:var(--primary);
  padding:8px 14px;
  border:none;
  border-radius:12px;
  font-weight:700;
  cursor:pointer;
}

.container{
  max-width:1400px;
  margin:40px auto;
  padding:0 20px;
}

.hero{
  background:linear-gradient(135deg,#0f172a,#134e4a);
  color:#fff;
  padding:30px;
  border-radius:24px;
  margin-bottom:30px;
}

.grid{
  display:grid;
  gap:24px;
}

.card{
  background:var(--card);
  padding:25px;
  border-radius:24px;
  box-shadow:var(--shadow);
}

table{
  width:100%;
  border-collapse:collapse;
}
th,td{
  padding:12px;
  border-bottom:1px solid var(--line);
  text-align:right;
}
th{background:#f8fafc}

button{
  padding:6px 12px;
  border:none;
  border-radius:8px;
  cursor:pointer;
}

.btn-approve{background:#16a34a;color:#fff}
.btn-reject{background:#dc2626;color:#fff}
.btn-delete{background:#991b1b;color:#fff}

textarea{
  width:100%;
  padding:8px;
  border-radius:8px;
  border:1px solid #ccc;
}
</style>
</head>

<body>

<div class="topbar">
  <h2>لوحة المسؤول</h2>
  <button class="logout-btn" onclick="logout()">تسجيل الخروج</button>
</div>

<div class="container">

<div class="hero">
  <h1>إدارة النظام</h1>
</div>

<!-- الموظفين -->
<div class="card">
<h3>جميع الموظفين</h3>
<table>
<thead>
<tr>
<th>الاسم</th>
<th>رقم الهوية</th>
<th>القسم</th>
<th>المسمى</th>
<th>الراتب</th>
<th>الحالة</th>
<th>حذف</th>
</tr>
</thead>
<tbody id="employeesTable"></tbody>
</table>
</div>

<!-- الطلبات -->
<div class="card">
<h3>جميع الطلبات</h3>
<table>
<thead>
<tr>
<th>الموظف</th>
<th>النوع</th>
<th>التفاصيل</th>
<th>الحالة</th>
<th>رد الإدارة</th>
<th>إجراء</th>
</tr>
</thead>
<tbody id="requestsTable"></tbody>
</table>
</div>

<!-- الملفات -->
<div class="card">
<h3>الملفات المرفوعة</h3>
<table>
<thead>
<tr>
<th>الموظف</th>
<th>الملف</th>
</tr>
</thead>
<tbody id="filesTable"></tbody>
</table>
</div>

</div>

<script>
const API = "https://daring-trust-production-8c34.up.railway.app";

/* ============================= */
/* تحميل الموظفين */
async function loadEmployees(){
  const res = await fetch(API + "/employees");
  const data = await res.json();
  const table = document.getElementById("employeesTable");
  table.innerHTML="";

  data.forEach(emp=>{
    table.innerHTML += `
      <tr>
        <td>${emp.name}</td>
        <td>${emp.national_id}</td>
        <td>${emp.department || "-"}</td>
        <td>${emp.position || "-"}</td>
        <td>${emp.salary || "-"}</td>
        <td>${emp.status}</td>
        <td>
          <button class="btn-delete" onclick="deleteEmployee(${emp.id})">حذف</button>
        </td>
      </tr>
    `;
  });
}

/* حذف موظف */
async function deleteEmployee(id){
  await fetch(API + "/employees/" + id, {method:"DELETE"});
  loadEmployees();
}

/* ============================= */
/* تحميل الطلبات */
async function loadRequests(){
  const res = await fetch(API + "/requests");
  const data = await res.json();
  const table = document.getElementById("requestsTable");
  table.innerHTML="";

  data.forEach(r=>{
    table.innerHTML += `
      <tr>
        <td>${r.name}</td>
        <td>${r.type}</td>
        <td>${r.details}</td>
        <td>${r.status}</td>
        <td>
          <textarea id="reply_${r.id}">${r.admin_reply || ""}</textarea>
        </td>
        <td>
          <button class="btn-approve" onclick="updateRequest(${r.id},'approved')">اعتماد</button>
          <button class="btn-reject" onclick="updateRequest(${r.id},'rejected')">رفض</button>
        </td>
      </tr>
    `;
  });
}

async function updateRequest(id,status){
  const reply = document.getElementById("reply_"+id).value;

  await fetch(API + "/requests/" + id,{
    method:"PUT",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify({status,admin_reply:reply})
  });

  loadRequests();
}

/* ============================= */
/* تحميل الملفات */
async function loadFiles(){
  const res = await fetch(API + "/files");
  const data = await res.json();
  const table = document.getElementById("filesTable");
  table.innerHTML="";

  data.forEach(f=>{
    table.innerHTML += `
      <tr>
        <td>${f.name}</td>
        <td><a href="/uploads/${f.file_path}" target="_blank">${f.file_name}</a></td>
      </tr>
    `;
  });
}

function logout(){
  window.location.href="/";
}

loadEmployees();
loadRequests();
loadFiles();
</script>

</body>
</html>
